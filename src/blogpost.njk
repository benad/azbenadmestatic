---
permalink: "blog/{{ page.date | getYear }}/{{ page.date | getMonth }}/{{ page.date | getDay }}/{{ title | slugify }}/"
---
{% include 'header.njk' %}
			<header>
				<h1>Benad's Web Site</h1>
				<h2>{{ title }}</h2>
			</header>
			<div class="site-layout">
{% include 'sidebar.njk' %}
				<section>
				{{ content | safe }}
				<p>Published on {{ page.date | readableDate("LLLL d, yyyy 'at' T ZZZZ", zone) }}</p>
				{% set previousPost = collections.post | getPreviousCollectionItem(page) %}
				{% set nextPost = collections.post | getNextCollectionItem(page) %}
				{% if previousPost %}<p>Older post: <a href="{{ previousPost.url }}">{{ previousPost.data.title }}</a></p>{% endif %}
				{% if nextPost %}<p>Newer post: <a href="{{ nextPost.url }}">{{ nextPost.data.title }}</a></p>{% endif %}
				</section>
			</div>
{% include 'footer.njk' %}